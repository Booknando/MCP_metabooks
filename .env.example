# =====================================================================
# MODO DE OPERAÇÃO
# =====================================================================
# Multi-tenant: cada editora envia as próprias credenciais por header HTTP.
# Recomendado para a MVB usar com várias editoras do catálogo.
# Quando true, o servidor NÃO usa credenciais de ambiente para metadados
# (cada requisição precisa trazer as suas).
REQUIRE_TENANT_CREDENTIALS=true

# Se preferir SINGLE-TENANT (uma instância = um login fixo), deixe
# REQUIRE_TENANT_CREDENTIALS vazio/false e preencha as credenciais abaixo.

# =====================================================================
# CREDENCIAIS DE AMBIENTE (usadas só no modo single-tenant ou como fallback)
# =====================================================================
# Produção via login:
# METABOOKS_USERNAME=seu_usuario
# METABOOKS_PASSWORD=sua_senha
# Staging/RC via token estático de metadados:
# METABOOKS_METADATA_TOKEN=token-de-metadata
# Capas e mídia (opcionais):
# METABOOKS_COVER_TOKEN=token-de-cover
# METABOOKS_MMO_TOKEN=token-de-mmo

# =====================================================================
# AMBIENTE DA API (URL base padrão; cada editora pode sobrescrever via header)
# =====================================================================
# Produção (padrão): https://api.metabooks.com/api/v2
# Staging:           https://staging.kubernetes.br.metabooks.com/api/v2
# RC:                https://rc.kubernetes.br.metabooks.com/api/v2
METABOOKS_BASE_URL=https://api.metabooks.com/api/v2

# =====================================================================
# SERVIDOR
# =====================================================================
TRANSPORT=http
PORT=3000

# Gateway de acesso ao /mcp (RECOMENDADO online). Gere com: openssl rand -hex 32
# MCP_AUTH_TOKEN=um-segredo-bem-aleatorio

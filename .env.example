# =====================================================================
# Metabooks MCP Server — referência de variáveis de ambiente
# =====================================================================
# Uso recomendado: rodar localmente pelo Claude Desktop (transporte stdio).
# Estas variáveis vão no bloco "env" do claude_desktop_config.json
# (veja o README), e NÃO num arquivo .env. Este arquivo serve só de referência.

# =====================================================================
# CREDENCIAIS METABOOKS — escolha UMA forma de autenticar metadados
# =====================================================================
# (A) Produção, via login usuário/senha:
METABOOKS_USERNAME=seu_usuario
METABOOKS_PASSWORD=sua_senha

# (B) Staging/RC, via token estático de metadados (alternativa ao login):
# METABOOKS_METADATA_TOKEN=token-de-metadata

# Capas e mídia (opcionais — exigem tokens dedicados da MVB):
# METABOOKS_COVER_TOKEN=token-de-cover
# METABOOKS_MMO_TOKEN=token-de-mmo

# =====================================================================
# AMBIENTE DA API (opcional; padrão = produção)
# =====================================================================
# Produção (padrão): https://api.metabooks.com/api/v2
# Staging:           https://staging.kubernetes.br.metabooks.com/api/v2
# RC:                https://rc.kubernetes.br.metabooks.com/api/v2
# METABOOKS_BASE_URL=https://api.metabooks.com/api/v2

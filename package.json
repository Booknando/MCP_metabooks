{
  "name": "metabooks-mcp-server",
  "version": "2.0.0",
  "description": "Servidor MCP (somente leitura) para a API REST v2 da Metabooks: metadados bibliográficos, capas, arquivos de mídia (MMO) e dados de editoras.",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "start": "node dist/index.cjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.cjs",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
